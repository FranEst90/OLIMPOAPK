# Copia este archivo a .env y completa los valores para desarrollo local.
# En Railway estas mismas variables se configuran como env vars del
# proyecto (no se usa .env ahí).

# Bot de autenticación OLIMPO (exclusivo, NO el de ALFA-1)
OLIMPO_BOT_TOKEN=

# Telegram IDs con acceso al panel de Admin, separados por coma
OLIMPO_ADMINS=

# Chat/canal donde llegan las alertas de auditoría de los módulos (cobros,
# reembolsos, accesos fallidos, ver MODULOS.md). Opcional: si no lo
# defines, las alertas se mandan por DM a cada ID de OLIMPO_ADMINS.
OLIMPO_LOG_CHANNEL_ID=

# SMSPool
SMSPOOL_API_KEY=

# Reservado para firmar sesiones si en el futuro se implementa (ver auth.py)
OLIMPO_SESSION_SECRET=

# Ruta del archivo SQLite. Opcional: si no lo defines se crea olimpo.db
# en la carpeta del proyecto, separado de la base de datos de Railway.
OLIMPO_DB_PATH=olimpo.db
